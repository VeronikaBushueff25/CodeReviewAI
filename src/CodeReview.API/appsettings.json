{
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5432;Database=codereview_db;Username=postgres;Password=postgres;Include Error Detail=true",
    "Redis": "localhost:6379,abortConnect=false"
  },
  "Jwt": {
    "Secret": "CHANGE_ME_IN_PRODUCTION_MUST_BE_AT_LEAST_32_CHARS_LONG",
    "Issuer": "CodeReviewAI",
    "Audience": "CodeReviewAI.Client",
    "ExpiryMinutes": "60"
  },
  "GitHub": {
    "ClientId": "YOUR_GITHUB_OAUTH_APP_CLIENT_ID",
    "ClientSecret": "YOUR_GITHUB_OAUTH_APP_CLIENT_SECRET",
    "RedirectUri": "http://localhost:4200/auth/github/callback"
  },
  "AI": {
    "ApiKey": "YOUR_HUGGINGFACE_API_KEY"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://your-production-domain.com"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "EnableSensitiveDataLogging": false
}
